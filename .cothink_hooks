#!/bin/bash
################################################################################
# .cothink_hooks
# Shell hooks for cothink-shell
# 
# Hook functions allow you to execute custom logic at various points in
# cothink-shell's execution. Define hook functions with the pattern:
#   hook_<hook_name>() { ... }
#
# Available hooks:
#   - hook_pre_interactive()      Before entering interactive mode
#   - hook_post_interactive()     After exiting interactive mode
#   - hook_pre_execute()          Before executing a command
#   - hook_post_execute()         After executing a command
#   - hook_pre_passthrough()      Before passing args to cothink-system
#   - hook_post_passthrough()     After cothink-system completes
#   - hook_pre_login()            Before login shell mode
#   - hook_post_login()           After login shell mode
#   - hook_task_spawned()         When a subagent spawns
#   - hook_task_completed()       When a subagent completes
#
################################################################################

################################################################################
# Example: Pre-execution setup
################################################################################

hook_pre_execute() {
    local cmd="$1"
    if [[ "$cmd" == *"run"* ]]; then
        /home/adrian/cothink-system/pip_btop.sh start
    fi
}

################################################################################
# Example: Post-execution logging
################################################################################

hook_post_execute() {
    local exit_code="$1"
    local cmd="$2"
    if [[ "$cmd" == *"run"* ]]; then
        /home/adrian/cothink-system/pip_btop.sh stop
    fi
}

################################################################################
# Example: Pre-passthrough environment setup
################################################################################

hook_pre_passthrough() {
    /home/adrian/cothink-system/pip_btop.sh start
}

################################################################################
# Example: Post-passthrough result handling
################################################################################

hook_post_passthrough() {
    local exit_code="$1"
    /home/adrian/cothink-system/pip_btop.sh stop
}

hook_pre_run() {
    /home/adrian/cothink-system/pip_btop.sh start
}

hook_post_run() {
    /home/adrian/cothink-system/pip_btop.sh stop
}

