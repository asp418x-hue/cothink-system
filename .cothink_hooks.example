#!/bin/bash
################################################################################
# .cothink_hooks.example
# Real-world hook examples for cothink-shell
# Copy to ~/.cothink_hooks or ~/.cothink_hooks.local to use
################################################################################

################################################################################
# 1. Logging & Audit Trail
################################################################################

hook_pre_execute() {
    local cmd="$1"
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] EXECUTE: $cmd" >> ~/.cothink_shell.log
}

hook_post_execute() {
    local exit_code="$1"
    local cmd="$2"
    local status=$( [[ $exit_code -eq 0 ]] && echo "OK" || echo "FAIL" )
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] RESULT: $cmd [$status]" >> ~/.cothink_shell.log
}

################################################################################
# 2. Environment Setup for cothink-system
################################################################################

hook_pre_passthrough() {
    # Set Rust logging
    export RUST_LOG="${RUST_LOG:-info}"
    
    # Set cothink environment
    export COTHINK_TELEMETRY="${COTHINK_TELEMETRY:-1}"
    
    # Check minimum memory requirement
    local avail_mem_kb=$(awk '/MemAvailable/ {print $2}' /proc/meminfo)
    if [[ $avail_mem_kb -lt 262144 ]]; then  # 256MB
        echo "[WARNING] Low memory: ${avail_mem_kb}KB available" >&2
    fi
}

hook_post_passthrough() {
    local exit_code="$1"
    shift
    local args=("$@")
    
    if [[ $exit_code -eq 0 ]]; then
        echo "✓ cothink-system completed successfully"
    else
        echo "✗ cothink-system exited with code: $exit_code" >&2
    fi
}

################################################################################
# 3. Interactive Mode Enhancements
################################################################################

hook_pre_interactive() {
    clear
    cat << 'EOF'
╔══════════════════════════════════════════════════════════════════╗
║           cothink-shell - Task Orchestration Engine              ║
║                                                                  ║
║  Commands: run | status | shell | clear | help | exit          ║
╚══════════════════════════════════════════════════════════════════╝

EOF
}

hook_post_interactive() {
    local exit_code="$1"
    echo ""
    echo "Session ended (exit: $exit_code)"
}

hook_pre_command() {
    local cmd="$1"
    local args="$2"
    # Could add input validation here
    # if [[ "$cmd" == "run" ]] && ! [[ "$args" =~ ^[0-9]+$ ]]; then
    #     echo "Invalid agent count" >&2
    #     return 1
    # fi
    :
}

################################################################################
# 4. Resource Monitoring
################################################################################

hook_status_display() {
    # Show additional system info beyond default status
    echo ""
    echo "System Resources:"
    
    if command -v free &>/dev/null; then
        echo "  Memory: $(free -h | awk 'NR==2 {print $3 " / " $2}')"
    fi
    
    if command -v uptime &>/dev/null; then
        echo "  Uptime: $(uptime | awk -F'up' '{print $2}' | cut -d',' -f1)"
    fi
    
    if [[ -f /proc/loadavg ]]; then
        local load=$(cat /proc/loadavg | awk '{print $1, $2, $3}')
        echo "  Load Average: $load"
    fi
}

################################################################################
# 5. Task Execution Tracking
################################################################################

hook_pre_run() {
    local agent_count="$1"
    echo "[$(date '+%H:%M:%S')] Starting orchestrator with $agent_count agents..."
}

hook_post_run() {
    local exit_code="$1"
    local agent_count="$2"
    
    if [[ $exit_code -eq 0 ]]; then
        echo "[$(date '+%H:%M:%S')] ✓ Orchestrator completed ($agent_count agents)"
    else
        echo "[$(date '+%H:%M:%S')] ✗ Orchestrator failed (exit: $exit_code)" >&2
    fi
}

